{
  "name": "postgres-users-connector",
  "config": {
    "connector.class": "io.debezium.connector.postgresql.PostgresConnector",

    "database.hostname": "${CDC_POSTGRES_HOST}",
    "database.port": "${CDC_POSTGRES_PORT}",
    "database.user": "${CDC_POSTGRES_USER}",
    "database.password": "${CDC_POSTGRES_PASSWORD}",
    "database.dbname": "${CDC_POSTGRES_DB}",
    "topic.prefix": "${CDC_TOPIC_PREFIX}",
    "plugin.name": "pgoutput",
    "slot.name": "debezium_slot",
    "publication.name": "debezium_publication",
    "publication.autocreate.mode": "filtered",
    "table.include.list": "public.users",
    "snapshot.mode": "initial",
    "tombstones.on.delete": "false"
  }
}